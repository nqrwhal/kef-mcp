# ---- copy this file to ".env" on your Docker host and fill in values ----

# --- KEF speaker (on your LAN) ---
# The speaker's local IP. Find it in the KEF Connect app (Settings > device)
# or your router's client list. Give it a DHCP reservation so it never changes.
# (Reserve it to the speaker's Wi-Fi MAC, since the KEF is on Wi-Fi.)
KEF_HOST=192.168.4.138

# The KEF's name as it appears as a Spotify Connect device.
# Substring match is enough (e.g. "LSX" matches "LSX II-03c707").
KEF_DEVICE_NAME=LSX

# Default volume (0-100) applied when play_on_kef runs without an explicit one.
KEF_DEFAULT_VOLUME=25

# --- Spotify (Premium) ---
# From your Spotify Developer app (https://developer.spotify.com/dashboard).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Obtained once by running auth_spotify.py (see README step 2).
SPOTIFY_REFRESH_TOKEN=

# --- Poke tunnel ---
# Your Poke API key from https://poke.com/kitchen/api-keys
# The poke-tunnel container uses this to authenticate and forward the MCP
# server up to your Poke agent (no port-forwarding / Cloudflare needed).
POKE_API_KEY=
# Display name for the connection as it appears in Poke.
POKE_TUNNEL_NAME=KEF + Spotify

# --- Optional: extra bearer auth on the MCP server ---
# Leave BLANK when using the Poke tunnel: the server publishes no host port, so
# the authenticated tunnel is the only way in. The Poke tunnel does NOT forward a
# bearer token to the local server, so setting this would block it.
# Only set it if you expose the server some other way (e.g. your own reverse proxy
# that adds the header). Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=
